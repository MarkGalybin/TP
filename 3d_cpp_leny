#include <cmath>
#include <string>

using namespace std;

const double PI = 3.14159265358979323846;

class Shape {
public:
    virtual ~Shape() {}
    virtual string calculateArea() = 0;
};

class Pyramid : public Shape {   
private:
    double a; 
    double h;  
    
public:
    Pyramid() : a(-1), h(-1) {}
    
    void setA(double x) { a = x; }
    void setH(double x) { h = x; }
    
    string calculateArea() override {
        if (a == -1 || h == -1) return "недостаточно данных";
        double s = a * a + 2 * a * sqrt(h * h + (a / 2) * (a / 2));
        return "Площадь пирамиды: " + to_string(s);
    }
};

class Parallelepiped : public Shape {
protected:
    double a;  
    double c;  
    
public:
    Parallelepiped() : a(-1), b(-1), c(-1) {}
    
    void setA(double x) { a = x; }
    void setB(double x) { b = x; }
    void setC(double x) { c = x; }
    
    string calculateArea() override {
        if (a == -1 || b == -1 || c == -1) return "недостаточно данных";
        double s = 2 * (a * b + a * c + b * c);
        return "Площадь параллелепипеда: " + to_string(s);
    }
};

class Cube : public Parallelepiped {
public:
    Cube() : Parallelepiped() {}
    
    void setA(double x) { a = b = c = x; }
    string calculateArea() override {
        if (a == -1) return "недостаточно данных";
        double s = 6 * a * a;
        return "Площадь куба: " + to_string(s);
    }
};

class Sphere : public Shape {
private:
    double r; 
public:
    Sphere() : r(-1) {}
    
    void setR(double x) { r = x; }
    
    string calculateArea() override {
        if (r == -1) return "недостаточно данных";
        
        double s = 4 * PI * r * r;
        return "Площадь сферы: " + to_string(s);
    }
};

class Cylinder : public Shape {
private:
    double r;  
    double h;  
    
public:
    Cylinder() : r(-1), h(-1) {}
    
    void setR(double x) { r = x; }
    void setH(double x) { h = x; }
    
    string calculateArea() override {
        if (r == -1 || h == -1) return "недостаточно данных";
        
        double s = 2 * PI * r * (r + h);
        return "Площадь цилиндра: " + to_string(s);
    }
};
